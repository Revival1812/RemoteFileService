APP_NAME=paper-ingestion-service
APP_ENV=local
LOG_LEVEL=INFO
ENABLE_PUBLIC_DOCS=true
MAX_REQUEST_BYTES=2000000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/papers
REDIS_URL=redis://redis:6379/0
QUEUE_MODE=inline
MAX_RETRY_COUNT=3

APP_API_KEYS=dev-secret-change-me
APP_ADMIN_API_KEYS=dev-admin-secret-change-me

ENABLE_DIFY_SYNC=false
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_KB_API_KEY=
DIFY_PAPERS_DATASET_ID=
DIFY_INDEXING_TECHNIQUE=high_quality
DIFY_POLL_INTERVAL_SECONDS=1
DIFY_INDEX_TIMEOUT_SECONDS=120

ENABLE_NEO4J_SYNC=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

ENABLE_OBJECT_STORAGE=false
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

ENABLE_EXTERNAL_RETRIEVAL_API=false

